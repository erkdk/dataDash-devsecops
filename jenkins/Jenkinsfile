pipeline {
    agent {
        label 'build'
    }

    environment {
        HARBOR_REGISTRY = 'registry.local'
        HARBOR_PROJECT = 'datadash'
        BACKEND_IMAGE = "${HARBOR_REGISTRY}/${HARBOR_PROJECT}/backend"
        FRONTEND_IMAGE = "${HARBOR_REGISTRY}/${HARBOR_PROJECT}/frontend"
        K8S_NAMESPACE = 'datadash'
    }

    stages {
        // Stage 1: Code Checkout
        stage('Checkout Code') {
            steps {
                echo 'Stage 1: Checking out source code...'
                
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: 'develop']],
                    extensions: [],
                    userRemoteConfigs: [[
                        url: 'https://github.com/erkdk/dataDash-devsecops.git'
                    ]]
                ])
                
                script {
                    sh 'echo "Checkout successful!"'
                    sh 'echo "Build Number: ${BUILD_NUMBER}"'
                }
            }
        }

        // Stage 2: Build Docker Images
        stage('Build Docker Images') {
            steps {
                echo 'Stage 2: Building Docker images...'
                
                script {
                    // Clean up any existing images first
                    sh """
                    docker rmi ${BACKEND_IMAGE}:latest 2>/dev/null || true
                    docker rmi ${FRONTEND_IMAGE}:latest 2>/dev/null || true
                    """
                    
                    // Build Backend Image
                    sh """
                    docker build -t ${BACKEND_IMAGE}:${BUILD_NUMBER} \
                                 -t ${BACKEND_IMAGE}:latest \
                                 ./server
                    """
                    
                    // Build Frontend Image  
                    sh """
                    docker build -t ${FRONTEND_IMAGE}:${BUILD_NUMBER} \
                                 -t ${FRONTEND_IMAGE}:latest \
                                 ./client
                    """
                    
                    sh 'echo "Docker images built successfully"'
                    sh 'docker images | grep ${HARBOR_REGISTRY}'
                }
            }
        }

        // Stage 3: Security Scan with Trivy
        stage('Security Scan with Trivy') {
            steps {
                echo 'Stage 3: Scanning container images for vulnerabilities...'
                
                script {
                    // Scan Backend Image
                    sh """
                    trivy image --exit-code 0 \
                                --severity HIGH,CRITICAL \
                                --format table \
                                ${BACKEND_IMAGE}:${BUILD_NUMBER}
                    """
                    
                    // Scan Frontend Image
                    sh """
                    trivy image --exit-code 0 \
                                --severity HIGH,CRITICAL \
                                --format table \
                                ${FRONTEND_IMAGE}:${BUILD_NUMBER}
                    """
                    
                    sh 'echo "Security scanning completed"'
                }
            }
        }

        // Stage 4: Push to Harbor Registry
        stage('Push to Harbor Registry') {
            steps {
                echo 'Stage 4: Pushing images to Harbor registry...'
                
                script {
                    // Login to Harbor
                    withCredentials([usernamePassword(
                        credentialsId: 'harbor-credentials',
                        usernameVariable: 'HARBOR_USERNAME',
                        passwordVariable: 'HARBOR_PASSWORD'
                    )]) {
                        sh """
                        echo \$HARBOR_PASSWORD | docker login ${HARBOR_REGISTRY} -u \$HARBOR_USERNAME --password-stdin
                        """
                    }
                    
                    // Push Backend Image
                    sh """
                    docker push ${BACKEND_IMAGE}:${BUILD_NUMBER}
                    docker push ${BACKEND_IMAGE}:latest
                    """
                    
                    // Push Frontend Image
                    sh """
                    docker push ${FRONTEND_IMAGE}:${BUILD_NUMBER}
                    docker push ${FRONTEND_IMAGE}:latest
                    """
                    
                    sh 'echo "Images successfully pushed to Harbor"'
                }
            }
        }
//----------------------------------
        // Stage 5: Deploy to K3s

        // Stage 5: Deploy to K3s
        stage('Deploy to K3s') {
            steps {
                echo 'Stage 5: Deploying to K3s cluster...'
                
                // Load kubeconfig from Jenkins credentials
                withCredentials([file(credentialsId: 'k3s-kubeconfig', variable: 'KUBECONFIG')]) {
                    script {
                        // Set KUBECONFIG environment variable
                        env.KUBECONFIG = "${KUBECONFIG}"
                        
                        // Create namespace if not exists
                        sh """
                        kubectl create namespace ${K8S_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
                        """
                        
                        // Create secret using Jenkins credentials
                        withCredentials([string(credentialsId: 'mongodb-uri', variable: 'MONGODB_URI_SECRET')]) {
                            sh """
                            kubectl create secret generic datadash-secrets \\
                              --from-literal=mongodb-uri='${MONGODB_URI_SECRET}' \\
                              -n ${K8S_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -
                            """
                        }
                        
                        // First, check current state
                        sh """
                        echo "=== Current State Before Deployment ==="
                        kubectl get deployments,replicasets,pods -n ${K8S_NAMESPACE} || true
                        """
                        
                        // Apply all Kubernetes manifests
                        sh """
                        kubectl apply -f k8s/namespace.yaml
                        kubectl apply -f k8s/backend-service.yaml
                        kubectl apply -f k8s/backend-deployment.yaml
                        kubectl apply -f k8s/frontend-service.yaml
                        kubectl apply -f k8s/frontend-deployment.yaml
                        kubectl apply -f k8s/ingress.yaml
                        """

                        // Wait a moment for resources to be created
                        sh "sleep 10"
                        
                        // Check what was deployed
                        sh """
                        echo "=== Deployed Resources ==="
                        kubectl get deployments,replicasets,pods -n ${K8S_NAMESPACE}
                        echo ""
                        echo "=== Backend Deployment Details ==="
                        kubectl describe deployment datadash-backend -n ${K8S_NAMESPACE}
                        """
                        
                        // Check pod events and logs for failing pods
                        sh """
                        echo "=== Pod Events ==="
                        kubectl get events -n ${K8S_NAMESPACE} --sort-by='.lastTimestamp'
                        echo ""
                        echo "=== Failing Pods Details ==="
                        kubectl get pods -n ${K8S_NAMESPACE} --field-selector=status.phase!=Running -o name | while read pod; do
                            echo "=== Details for \$pod ==="
                            kubectl describe \$pod -n ${K8S_NAMESPACE}
                            echo "=== Logs for \$pod ==="
                            kubectl logs \$pod -n ${K8S_NAMESPACE} --tail=50 || true
                            echo ""
                        done
                        """
                        
                        // Now try the rollout restart with better debugging
                        sh """
                        echo "=== Restarting Backend Deployment ==="
                        kubectl rollout restart deployment/datadash-backend -n ${K8S_NAMESPACE}
                        """
                        
                        // Wait for rollout with detailed progress
                        sh """
                        echo "=== Waiting for Rollout ==="
                        timeout 300s bash -c "
                            while true; do
                                kubectl rollout status deployment/datadash-backend -n ${K8S_NAMESPACE} && break
                                echo 'Rollout in progress...'
                                kubectl get pods -n ${K8S_NAMESPACE} -l app=datadash-backend
                                kubectl get replicasets -n ${K8S_NAMESPACE} -l app=datadash-backend
                                sleep 10
                            done
                        " || {
                            echo "=== Rollout Timed Out - Debugging Info ==="
                            kubectl get pods -n ${K8S_NAMESPACE} -o wide
                            kubectl describe deployment datadash-backend -n ${K8S_NAMESPACE}
                            kubectl get events -n ${K8S_NAMESPACE} --sort-by='.lastTimestamp' | tail -20
                            exit 1
                        }
                        """
                        
                        // Wait for frontend rollout
                        sh """
                        kubectl rollout status deployment/datadash-frontend -n ${K8S_NAMESPACE} --timeout=180s
                        """
                        
                        sh 'echo "Application successfully deployed to K3s"'
                        
                        // Show final deployment status
                        sh """
                        echo "=== Final Deployment Status ==="
                        kubectl get deployments -n ${K8S_NAMESPACE}
                        echo ""
                        echo "=== Final Pod Status ==="
                        kubectl get pods -n ${K8S_NAMESPACE} -o wide
                        echo ""
                        echo "=== Final Service Status ==="
                        kubectl get services -n ${K8S_NAMESPACE}
                        """
                    }
                }
            }
        }



//----------------------------------

	// Stage 6: Smoke Tests
        stage('Smoke Tests') {
            steps {
                echo 'Stage 6: Running smoke tests...'
                
                withCredentials([file(credentialsId: 'k3s-kubeconfig', variable: 'KUBECONFIG')]) {
                    script {
                        env.KUBECONFIG = "${KUBECONFIG}"
                        
                        // Test backend health endpoint
                        sh """
                        kubectl wait --for=condition=ready pod -l app=datadash-backend -n ${K8S_NAMESPACE} --timeout=60s
                        echo "Testing backend health endpoint..."
                        kubectl exec -n ${K8S_NAMESPACE} deployment/datadash-backend -- curl -s http://localhost:5000/health || echo "Backend health check failed"
                        """
                        
                        // Test frontend availability (via port-forward temporarily)
                        sh """
                        kubectl wait --for=condition=ready pod -l app=datadash-frontend -n ${K8S_NAMESPACE} --timeout=60s
                        echo "Frontend pods are ready"
                        """
                        
                        sh 'echo "Smoke tests completed successfully"'
                    }
                }
            }
        }
    }
    
    post {
        always {
            echo 'Pipeline execution completed'
            
            // Clean up local Docker images to save space
            script {
                sh """
                # Remove the specific images we built
                docker rmi ${BACKEND_IMAGE}:${BUILD_NUMBER} 2>/dev/null || true
                docker rmi ${BACKEND_IMAGE}:latest 2>/dev/null || true
                docker rmi ${FRONTEND_IMAGE}:${BUILD_NUMBER} 2>/dev/null || true
                docker rmi ${FRONTEND_IMAGE}:latest 2>/dev/null || true
                
                # Logout from Harbor
                docker logout ${HARBOR_REGISTRY} 2>/dev/null || true
                
                # Clean up dangling images
                docker image prune -f 2>/dev/null || true
                """
                
                sh 'echo "Cleaned up local Docker images"'
            }
        }
        
        success {
            echo 'Pipeline executed successfully! Application deployed to K3s.'
            // You can add notifications here (Slack, Email, etc.)
        }
        
        failure {
            echo 'Pipeline execution failed! Check the logs above.'
            // You can add failure notifications here
        }
    }
}
